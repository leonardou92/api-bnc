BNC_CLIENT_GUID=00000000-0000-0000-0000-000000000000
BNC_MASTER_KEY=ffffffffffffffffffffffffffffffff
BNC_URL_BASE=https://servicios.bncenlinea.com:16500/api

# Identificación del cliente principal y asociados
BNC_CLIENT_ID=J000000000        # RIF del cliente principal afiliado al API
BNC_CHILD_CLIENT_ID=J000000000  # RIF del asociado (opcional)
BNC_BRANCH_ID=CS000             # Código de sucursal del asociado (opcional)

# Terminal por defecto para pagos C2P
BNC_TERMINAL_ID=TERMINAL001

# Parámetros por defecto para consultas/validaciones y VPOS
BNC_DEFAULT_BANK_CODE=191
BNC_AFFILIATION_NUMBER=AFI000000000

# JWT para proteger la API
# Usa un secreto largo, aleatorio y único en producción
# EJEMPLO (no usar en producción):
JWT_SECRET=MI_SECRETO_DE_EJEMPLO_NO_REAL
# Duración recomendada corta para producción (ej: 15 minutos)
JWT_EXPIRES_IN=15m

# Base de datos MySQL (usar el formato correcto para tu servidor)
DATABASE_URL="mysql://user:password@localhost:3306/api_bnc"